<script src="<?= $block->escapeUrl($block->getViewFileUrl('Hmh_OtsLogin::js/hyva/account/login.js')) ?>"></script>
<script>
    (() => {
        const init = () => {
            const form = document.getElementById('ots-request-form');

            if (!form || typeof window.initHmhOtsLogin !== 'function' || form.dataset.otsInitialized === 'true') {
                return;
            }

            window.initHmhOtsLogin(form);
            form.dataset.otsInitialized = 'true';
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init, { once: true });
        } else {
            init();
        }
    })();
</script>
