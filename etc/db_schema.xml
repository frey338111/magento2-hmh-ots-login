<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="hmh_ots_request" resource="default" engine="innodb" comment="HMH OTS Request">
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="customer_id" unsigned="true" nullable="false" comment="Customer ID"/>
        <column xsi:type="smallint" name="website_id" unsigned="true" nullable="false" comment="Website ID"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="varchar" name="code" nullable="false" length="255" comment="Code"/>
        <column xsi:type="boolean" name="status" nullable="false" default="0" comment="Status"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="HMH_OTS_REQUEST_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="hmh_ots_request"
                    column="customer_id"
                    referenceTable="customer_entity"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="foreign"
                    referenceId="HMH_OTS_REQUEST_WEBSITE_ID_STORE_WEBSITE_WEBSITE_ID"
                    table="hmh_ots_request"
                    column="website_id"
                    referenceTable="store_website"
                    referenceColumn="website_id"
                    onDelete="CASCADE"/>

        <index referenceId="HMH_OTS_REQUEST_CUSTOMER_ID" indexType="btree">
            <column name="customer_id"/>
        </index>
        <index referenceId="HMH_OTS_REQUEST_WEBSITE_ID" indexType="btree">
            <column name="website_id"/>
        </index>
        <index referenceId="HMH_OTS_REQUEST_CODE" indexType="btree">
            <column name="code"/>
        </index>
    </table>
</schema>
